---
import Container from "./Container.astro";

const links = [
  { href: "https://github.com/AZgeekster/Bug-Fab", label: "GitHub" },
  {
    href: "https://github.com/AZgeekster/Bug-Fab/tree/main/docs",
    label: "Docs",
  },
  { href: "https://bug-fab.fly.dev/", label: "Live demo" },
];
---

<header class="topbar">
  <Container>
    <div class="topbar__row">
      <a href="#top" class="brand" aria-label="Bug-Fab home">
        <svg class="brand__mark" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <!-- Pinned beetle / specimen mark -->
          <circle cx="12" cy="13" r="6" fill="currentColor"></circle>
          <circle cx="12" cy="13" r="3" fill="var(--bg)"></circle>
          <line x1="12" y1="2" x2="12" y2="7" stroke="currentColor" stroke-width="1.5"></line>
          <line x1="6" y1="11" x2="3" y2="9" stroke="currentColor" stroke-width="1.5"></line>
          <line x1="18" y1="11" x2="21" y2="9" stroke="currentColor" stroke-width="1.5"></line>
          <line x1="6" y1="15" x2="3" y2="17" stroke="currentColor" stroke-width="1.5"></line>
          <line x1="18" y1="15" x2="21" y2="17" stroke="currentColor" stroke-width="1.5"></line>
        </svg>
        <span class="brand__name">bug-fab</span>
        <span class="brand__alpha">0.1.0a1</span>
      </a>

      <nav class="nav" aria-label="Primary">
        {
          links.map((l) => (
            <a
              class="nav__link"
              href={l.href}
              rel={l.href.startsWith("http") ? "noopener" : undefined}
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </Container>
</header>

<style>
  .topbar {
    position: absolute;
    inset: 0 0 auto 0;
    z-index: 10;
    padding-block: var(--s-5);
  }

  .topbar__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-5);
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--s-2);
    color: var(--fg);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--t-sm);
    letter-spacing: 0.06em;
    text-transform: lowercase;
  }

  .brand__mark {
    color: var(--accent);
    transform: translateY(3px);
  }

  .brand__alpha {
    color: var(--mute);
    font-weight: 400;
    font-size: var(--t-xs);
    letter-spacing: 0.12em;
  }

  .nav {
    display: flex;
    gap: var(--s-5);
  }

  .nav__link {
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    color: var(--fg-soft);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    padding-block: 2px;
    border-bottom: 1px dashed transparent;
    transition:
      color 180ms var(--ease-out-quart),
      border-color 180ms var(--ease-out-quart);
  }

  .nav__link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent-dim);
  }

  @media (max-width: 540px) {
    .nav {
      gap: var(--s-3);
    }
    .nav__link {
      font-size: var(--t-xs);
    }
    .brand__alpha {
      display: none;
    }
  }
</style>
