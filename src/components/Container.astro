---
interface Props {
  width?: "default" | "narrow" | "full";
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { width = "default", as: Tag = "div", class: className = "" } = Astro.props;
---

<Tag class:list={["container", `container--${width}`, className]}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  .container--default {
    max-width: var(--container);
  }
  .container--narrow {
    max-width: var(--container-narrow);
  }
  .container--full {
    max-width: none;
    padding-inline: 0;
  }
</style>
