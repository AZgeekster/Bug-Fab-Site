---
import Container from "./Container.astro";
import SectionHeader from "./SectionHeader.astro";
import adapters from "../data/adapters.json";

type Status = "reference" | "community" | "sketch" | "wanted";

// Source of truth: BUG-FAB/repo/docs/ADAPTERS_REGISTRY.md, extracted at
// build time by scripts/extract-adapters.mjs (predev + prebuild). To
// update this table, edit the parent registry and re-run the build —
// do NOT hand-edit src/data/adapters.json.
const rows = adapters as Array<{
  name: string;
  language: string;
  status: Status;
  note: string;
  url: string;
  tier: number;
}>;

const statusMeta: Record<Status, { dot: string; label: string }> = {
  reference: { dot: "var(--accent)", label: "reference" },
  community: { dot: "#9aa0ff", label: "community" },
  sketch: { dot: "var(--warm-amber)", label: "sketch" },
  wanted: { dot: "var(--mute)", label: "wanted" },
};
---

<section class="adapters" id="adapters" data-anim="reveal">
  <Container>
    <SectionHeader
      label="Adapters"
      heading="Framework-agnostic by design."
      aside="The wire protocol is the contract. The Python adapter is one implementation. Anyone can write another."
    />

    <div class="table-wrap">
      <table class="adapters__table">
        <thead>
          <tr>
            <th scope="col">Framework</th>
            <th scope="col">Language</th>
            <th scope="col">Status</th>
            <th scope="col">Notes</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((r) => (
              <tr>
                <td class="adapters__name">
                  <a href={r.url} class="adapters__link" rel="noopener" target="_blank">
                    {r.name}
                    <svg
                      class="adapters__link-icon"
                      viewBox="0 0 16 16"
                      width="11"
                      height="11"
                      aria-hidden="true"
                    >
                      <path
                        d="M5 3h8v8M13 3L4 12"
                        stroke="currentColor"
                        stroke-width="1.8"
                        fill="none"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                </td>
                <td class="adapters__lang">{r.language}</td>
                <td>
                  <span class="status">
                    <span
                      class="status__dot"
                      style={`background:${statusMeta[r.status].dot}`}
                      aria-hidden="true"
                    />
                    <span class="status__label">{statusMeta[r.status].label}</span>
                  </span>
                </td>
                <td class="adapters__note">{r.note}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="adapters__cta aside">
      writing one?
      <a href="https://github.com/AZgeekster/Bug-Fab/blob/main/docs/ADAPTERS.md" rel="noopener">
        the adapter guide is here →
      </a>
    </p>
  </Container>
</section>

<style>
  .adapters {
    padding-block: var(--s-9);
  }

  .table-wrap {
    border: var(--hairline);
    border-radius: var(--r-2);
    background: var(--bg-elev);
    overflow-x: auto;
  }

  .adapters__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: var(--t-sm);
  }

  .adapters__table th,
  .adapters__table td {
    text-align: left;
    padding: var(--s-3) var(--s-4);
    vertical-align: middle;
  }

  .adapters__table thead th {
    color: var(--mute);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: var(--t-xs);
    font-weight: 500;
    border-bottom: var(--hairline);
    background: var(--accent-tint-3);
  }

  .adapters__table tbody tr {
    border-bottom: var(--hairline);
    transition: background 160ms var(--ease-out-quart);
  }
  .adapters__table tbody tr:last-child {
    border-bottom: 0;
  }
  .adapters__table tbody tr:hover {
    background: var(--accent-tint-4);
  }

  .adapters__name {
    color: var(--fg);
    font-weight: 500;
  }

  .adapters__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    color: inherit;
    border-bottom: 1px dashed transparent;
    transition:
      color 160ms var(--ease-out-quart),
      border-color 160ms var(--ease-out-quart);
  }

  .adapters__link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent-dim);
  }

  .adapters__link-icon {
    opacity: 0;
    transform: translate(-2px, 2px);
    transition:
      opacity 160ms var(--ease-out-quart),
      transform 200ms var(--ease-spring);
  }

  .adapters__link:hover .adapters__link-icon,
  .adapters__link:focus-visible .adapters__link-icon {
    opacity: 1;
    transform: translate(0, 0);
  }

  .adapters__lang,
  .adapters__note {
    color: var(--mute);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
  }

  .status__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    box-shadow: 0 0 8px currentColor;
  }

  .status__label {
    color: var(--fg-soft);
    text-transform: lowercase;
    letter-spacing: 0.06em;
  }

  .adapters__cta {
    margin-block-start: var(--s-5);
    text-align: right;
  }
  .adapters__cta a {
    color: var(--accent);
  }
  .adapters__cta a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--accent-dim);
  }
</style>
